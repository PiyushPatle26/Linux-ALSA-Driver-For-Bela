// SPDX-License-Identifier: GPL-2.0
/*
 * PocketBeagle2 + Bela Gem Multi audio overlay
 *
 * Hardware:
 *   TLV320AIC3106  — stereo codec (I2C 0x18) — playback + capture
 *   ES9080Q        — 8-channel DAC (I2C 0x48 R/W, 0x4C W/O) — playback only
 *   TLV320ADC3140  — stereo ADC ×2 (I2C 0x4C, 0x4D) — capture only
 *
 * Clock topology (identical to Stereo):
 *   McASP2 AHCLKX → P2.11 → TLV320AIC3106 MCLK
 *   TLV320AIC3106 PLL → P2.19 BCLK (256 clk/frame) → McASP2 + ES9080Q + ADC3140
 *   TLV320AIC3106 → P2.10 WCLK
 *
 * TDM slot mapping (8 slots × 32 bits = 256 clocks/frame):
 *   Slots 0-1: TLV320AIC3106  (P2.05 TX, P2.07 RX)
 *   Slots 0-7: ES9080Q        (P1.04 = AXR6, P1.19 = AXR3 → 4ch each)
 *   Slots 0-3: TLV320ADC3140  (P1.02 = AXR4, P2.31 = AXR8 ← 2ch each)
 *
 * ALSA device: 10 playback ch (2 TLV + 8 ES9080Q), 4 capture ch (2×ADC3140)
 *
 * BRING-UP ORDER:
 *   1. Apply this DTS — verify all 4 I2C devices detected
 *   2. Bring up TLV320AIC3106 only (same as Stereo)
 *   3. Add ES9080Q driver — verify 8ch playback
 *   4. Add ADC3140 — verify 4ch capture
 */

#include <dt-bindings/gpio/gpio.h>
#include "k3-pinctrl.h"

/dts-v1/;
/plugin/;

&{/chosen} {
	overlays {
		k3-am62-pocketbeagle2-bela-gem-multi.kernel = __TIMESTAMP__;
	};
};

/*
 * McASP2 — TDM8 mode, 8 slots × 32-bit
 *
 * serial-dir for Multi (verified by giuliomoro against schematic):
 *   AXR0 (P2.05) = TX → TLV320AIC3106 DIN  (SoC→codec, playback)
 *   AXR1 (P2.07) = RX ← TLV320AIC3106 DOUT (codec→SoC, capture)
 *   AXR3 (P1.19) = TX → ES9080Q DATA B (4ch, slots 4-7)
 *   AXR4 (P1.02) = RX ← TLV320ADC3140 #1 DOUT
 *   AXR6 (P1.04) = TX → ES9080Q DATA A (4ch, slots 0-3)
 *   AXR8 (P2.31) = RX ← TLV320ADC3140 #2 DOUT
 *
 * serializer index = AXR number (0-based).
 */
&mcasp2 {
	status = "okay";
	#sound-dai-cells = <0>;

	assigned-clocks = <&k3_clks 192 15>;
	assigned-clock-parents = <&k3_clks 192 18>;

	op-mode = <0>;      /* MCASP_IIS_MODE */
	tdm-slots = <8>;    /* 8 TDM slots for ES9080Q */

	serial-dir = <
		1 2 0 1   /* AXR0=TX(TLV-play), AXR1=RX(TLV-cap), AXR2=off, AXR3=TX(ES9080-B) */
		2 0 1 0   /* AXR4=RX(ADC3140-1), AXR5=off, AXR6=TX(ES9080-A), AXR7=off */
		2 0 0 0   /* AXR8=RX(ADC3140-2), rest inactive */
		0 0 0 0
	>;

	tx-num-evt = <1>;
	rx-num-evt = <1>;
};

&main_i2c1 {
	#address-cells = <1>;
	#size-cells = <0>;

	/* ---- TLV320AIC3106 — stereo codec ---- */
	tlv320aic3106: audio-codec@18 {
		compatible = "ti,tlv320aic3106";
		reg = <0x18>;
		#sound-dai-cells = <0>;
	};

	/*
	 * ---- ES9080Q — 8-channel DAC ----
	 * I2C addresses verified from bela_hw_settings.h and dtsi:
	 *   0x48 = primary (read/write registers 0–164, 224–255)
	 *   0x4C = secondary (write-only registers 192–203)
	 * CHIP_EN on GPIO0_53 (P2.18) via JP8 — hogged high in dtsi.
	 */
	es9080q: dac@48 {
		compatible = "ess,es9080q";
		reg = <0x48>;
		#sound-dai-cells = <0>;
		ess,write-only-addr = <0x4c>;
	};

	/*
	 * ---- TLV320ADC3140 — stereo ADC ×2 ----
	 * Addresses set by ADDR pin on each chip.
	 * TLV320ADC3140 driver already upstream: sound/soc/codecs/tlv320adcx140.c
	 * REPLACE addresses from schematic.
	 */
	tlv320adc3140_0: audio-codec@4c {
		compatible = "ti,tlv320adcx140";
		reg = <0x4c>;
		#sound-dai-cells = <0>;
		reset-gpios = <&main_gpio0 58 GPIO_ACTIVE_LOW>; /* check schematic */
	};

	tlv320adc3140_1: audio-codec@4d {
		compatible = "ti,tlv320adcx140";
		reg = <0x4d>;
		#sound-dai-cells = <0>;
		reset-gpios = <&main_gpio0 59 GPIO_ACTIVE_LOW>; /* check schematic */
	};
};

&{/} {
	bela_multi_mclk: bela-multi-mclk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <12288000>;
	};

	/*
	 * Multi-DAI sound card.
	 *
	 * Three DAI links:
	 *   Link 0: McASP2 ↔ TLV320AIC3106  (stereo I/O, codec clk master)
	 *   Link 1: McASP2 ↔ ES9080Q         (8ch playback, TDM slave)
	 *   Link 2: McASP2 ↔ ADC3140 ×2      (4ch capture, TDM slave)
	 *
	 * Note: All three share the same McASP2 and thus the same BCLK/WCLK
	 * generated by TLV320AIC3106. simple-audio-card supports multi-link via
	 * dai-link@ child nodes.
	 */
	bela_multi_sound: sound-bela-multi {
		compatible = "simple-audio-card";
		simple-audio-card,name = "BelaGemMulti";

		/* DAI link 0: TLV320AIC3106 stereo I/O */
		simple-audio-card,dai-link@0 {
			reg = <0>;
			format = "dsp_b";
			bitclock-inversion;
			bitclock-master = <&multi_tlv_codec>;
			frame-master   = <&multi_tlv_codec>;

			multi_tlv_cpu: cpu {
				sound-dai = <&mcasp2>;
			};
			multi_tlv_codec: codec {
				sound-dai = <&tlv320aic3106>;
				clocks = <&bela_multi_mclk>;
				dai-tdm-slot-num   = <2>;
				dai-tdm-slot-width = <32>;
			};
		};

		/* DAI link 1: ES9080Q 8-channel playback */
		simple-audio-card,dai-link@1 {
			reg = <1>;
			format = "dsp_b";
			bitclock-inversion;
			/* ES9080Q is TDM slave — codec NOT master here */
			bitclock-master = <&multi_es9080_cpu>;
			frame-master   = <&multi_es9080_cpu>;

			multi_es9080_cpu: cpu {
				sound-dai = <&mcasp2>;
				system-clock-direction-out;
			};
			codec {
				sound-dai = <&es9080q>;
				dai-tdm-slot-num   = <8>;
				dai-tdm-slot-width = <32>;
			};
		};

		/* DAI link 2: TLV320ADC3140 4-channel capture */
		simple-audio-card,dai-link@2 {
			reg = <2>;
			format = "dsp_b";
			bitclock-inversion;
			bitclock-master = <&multi_adc_cpu>;
			frame-master   = <&multi_adc_cpu>;

			multi_adc_cpu: cpu {
				sound-dai = <&mcasp2>;
			};
			codec@0 {
				sound-dai = <&tlv320adc3140_0>;
				dai-tdm-slot-num   = <2>;
				dai-tdm-slot-width = <32>;
			};
			codec@1 {
				sound-dai = <&tlv320adc3140_1>;
				dai-tdm-slot-num   = <2>;
				dai-tdm-slot-width = <32>;
			};
		};
	};
};
